# --- Docker / Node (см. Dockerfile) ---
# Порт, на котором слушает `node server.js` внутри контейнера
PORT=3000

# Картинка или GIF над приветственной карточкой (файл из public/, напр. /hero.gif)
# NEXT_PUBLIC_WELCOME_HERO_SRC=/hero-network.svg

# --- Сборка Next: задайте на этапе `docker build` / CI, если реклама нужна в проде ---
# ID рекламных блоков РСЯ из кабинета (после модерации). Без значений — слоты скрыты, context.js не грузится.
NEXT_PUBLIC_YANDEX_RTB_BLOCK_HEADER=
# Баннер между карточкой «Качество интернета» и Reachability (отдельный блок в РСЯ)
NEXT_PUBLIC_YANDEX_RTB_BLOCK_CONTENT=
NEXT_PUBLIC_YANDEX_RTB_BLOCK_FOOTER=

# Принудительно подгрузить context.js (1) даже без block id — для отладки; в проде обычно 0
NEXT_PUBLIC_YANDEX_RSYA_ENABLED=0

# Редко: другой URL скрипта (по умолчанию — ниже)
# NEXT_PUBLIC_YANDEX_RSYA_CONTEXT_URL=https://yandex.ru/ads/system/context.js

# --- Минимальный чеклист: Яндекс Облако + этот образ ---
# 1) Собрать образ: из каталога connection-checker → `docker build -t connection-checker:prod .`
# 2) Container Registry: `docker tag` + `docker push` в реестр облака
# 3) Serverless Container / ВМ: PORT=3000, NODE_ENV=production; ID блоков РСЯ — в образ на этапе сборки:
#    docker build --build-arg NEXT_PUBLIC_YANDEX_RTB_BLOCK_HEADER=R-A-... --build-arg NEXT_PUBLIC_YANDEX_RTB_BLOCK_CONTENT=R-A-... --build-arg NEXT_PUBLIC_YANDEX_RTB_BLOCK_FOOTER=R-A-... -t connection-checker:prod .
# 4) Публичный URL: HTTPS (сертификат в L7 / на ВМ — Caddy/Nginx + Let’s Encrypt)
# 5) После появления реальных block id: пересобрать образ, сверить отображение баннеров; при строгом CSP — разрешить домены РСЯ в next.config (см. комментарий в next.config.ts)
